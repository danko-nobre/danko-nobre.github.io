---
import { icons } from '@/lib/icons';

interface Props {
  name: string;
  class?: string;
  size?: number;
}

const { name, class: className = '', size = 24 } = Astro.props;
const path = icons[name] ?? '';
---

<svg
  class={className}
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
>
  <Fragment set:html={path} />
</svg>
