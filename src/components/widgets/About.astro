---
import Card from "@components/Card.astro";
import Icon from "@components/Icon.astro";
import SectionHeader from "@components/SectionHeader.astro";
import { getLocale, t } from "@/i18n/ui";

const locale = getLocale(Astro.currentLocale);
const strings = t(locale).about;
---

<section id="about" class="relative px-4" data-animate>
  <div class="max-w-6xl mx-auto">
    <SectionHeader label={strings.label} tag="About" description={strings.description} />

    <div class="grid md:grid-cols-2 gap-8">
      {
        strings.highlights.map((item) => (
          <Card>
            <div class="flex items-center gap-3 mb-3">
              <Icon name={item.icon} class="h-7 w-7 text-foreground group-hover:text-primary transition-colors duration-300 shrink-0" />
              <h3 class="text-xl font-bold font-mono group-hover:text-primary transition-colors">
                {item.title}
              </h3>
            </div>

            <p class="text-muted-foreground leading-relaxed">
              {item.description}
            </p>
          </Card>
        ))
      }
    </div>
  </div>
</section>
