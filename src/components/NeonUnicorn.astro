</div>

<style>
  .neon-unicorn {
    animation: neon-flicker 4s ease-in-out infinite;
  }

  .neon-yellow {
    fill: #ffec4a;
  }
  .neon-purple-g {
    fill: #8957ff;
  }
  .neon-violet {
    fill: #b57dff;
  }
  .neon-pink {
    fill: #ff26fa;
  }
  .neon-white {
    fill: #e6e7e8;
  }

  /* Staggered flicker per color group for a neon sign feel */
  .neon-yellow {
    animation: flicker-yellow 3.5s ease-in-out infinite;
  }
  .neon-pink {
    animation: flicker-pink 4s ease-in-out infinite 0.3s;
  }
  .neon-white {
    animation: flicker-white 5s ease-in-out infinite 0.7s;
  }
  .neon-violet {
    animation: flicker-violet 3s ease-in-out infinite 1s;
  }
  .neon-purple-g {
    animation: flicker-purple 4.5s ease-in-out infinite 0.5s;
  }

  /* Parent flicker: subtle overall pulse, stays bright */
  @keyframes neon-flicker {
    0%,
    100% {
      opacity: 0.95;
    }
    4% {
      opacity: 0.88;
    }
    6% {
      opacity: 0.97;
    }
    8% {
      opacity: 0.85;
    }
    10% {
      opacity: 0.95;
    }
    50% {
      y: 1;
    }
    52% {
      opacity: 0.88;
    }
    54% {
      opacity: 1;
    }
  }

  @keyframes flicker-yellow {
    0%,
    100% {
      opacity: 1;
      filter: drop-shadow(0 0 8px #ffec4a) drop-shadow(0 0 20px #ffec4a90)
        drop-shadow(0 0 40px #ffec4a40);
    }
    15% {
      opacity: 0.8;
      filter: drop-shadow(0 0 4px #ffec4a) drop-shadow(0 0 10px #ffec4a60);
    }
    16% {
      opacity: 1;
      filter: drop-shadow(0 0 12px #ffec4a) drop-shadow(0 0 28px #ffec4a90)
        drop-shadow(0 0 50px #ffec4a30);
    }
    50% {
      opacity: 0.9;
      filter: drop-shadow(0 0 6px #ffec4a) drop-shadow(0 0 16px #ffec4a70);
    }
    70% {
      opacity: 0.75;
      filter: drop-shadow(0 0 4px #ffec4a80) drop-shadow(0 0 12px #ffec4a40);
    }
    71% {
      opacity: 1;
      filter: drop-shadow(0 0 8px #ffec4a) drop-shadow(0 0 20px #ffec4a90)
        drop-shadow(0 0 40px #ffec4a40);
    }
  }

  @keyframes flicker-pink {
    0%,
    100% {
      opacity: 1;
      filter: drop-shadow(0 0 8px #ff26fa) drop-shadow(0 0 20px #ff26fa90)
        drop-shadow(0 0 40px #ff26fa40);
    }
    20% {
      opacity: 0.7;
      filter: drop-shadow(0 0 4px #ff26fa80) drop-shadow(0 0 12px #ff26fa40);
    }
    21% {
      opacity: 1;
      filter: drop-shadow(0 0 12px #ff26fa) drop-shadow(0 0 28px #ff26fa90)
        drop-shadow(0 0 50px #ff26fa30);
    }
    55% {
      opacity: 0.85;
      filter: drop-shadow(0 0 6px #ff26fa) drop-shadow(0 0 16px #ff26fa70);
    }
    80% {
      opacity: 0.7;
      filter: drop-shadow(0 0 4px #ff26fa80) drop-shadow(0 0 12px #ff26fa40);
    }
    82% {
      opacity: 1;
      filter: drop-shadow(0 0 8px #ff26fa) drop-shadow(0 0 20px #ff26fa90)
        drop-shadow(0 0 40px #ff26fa40);
    }
  }

  @keyframes flicker-white {
    0%,
    100% {
      opacity: 1;
      filter: drop-shadow(0 0 6px #e6e7e8) drop-shadow(0 0 16px #e6e7e890)
        drop-shadow(0 0 32px #e6e7e840);
    }
    30% {
      opacity: 0.75;
      filter: drop-shadow(0 0 4px #e6e7e880) drop-shadow(0 0 10px #e6e7e850);
    }
    32% {
      opacity: 1;
      filter: drop-shadow(0 0 10px #e6e7e8) drop-shadow(0 0 24px #e6e7e890)
        drop-shadow(0 0 40px #e6e7e830);
    }
    65% {
      opacity: 0.8;
      filter: drop-shadow(0 0 5px #e6e7e8) drop-shadow(0 0 14px #e6e7e860);
    }
    67% {
      opacity: 1;
      filter: drop-shadow(0 0 6px #e6e7e8) drop-shadow(0 0 16px #e6e7e890)
        drop-shadow(0 0 32px #e6e7e840);
    }
  }

  @keyframes flicker-violet {
    0%,
    100% {
      opacity: 1;
      filter: drop-shadow(0 0 8px #b57dff) drop-shadow(0 0 20px #b57dff90)
        drop-shadow(0 0 40px #b57dff40);
    }
    25% {
      opacity: 0.7;
      filter: drop-shadow(0 0 4px #b57dff80) drop-shadow(0 0 12px #b57dff40);
    }
    27% {
      opacity: 1;
      filter: drop-shadow(0 0 12px #b57dff) drop-shadow(0 0 28px #b57dff90)
        drop-shadow(0 0 50px #b57dff30);
    }
    60% {
      opacity: 0.75;
      filter: drop-shadow(0 0 5px #b57dff) drop-shadow(0 0 14px #b57dff60);
    }
    62% {
      opacity: 1;
      filter: drop-shadow(0 0 8px #b57dff) drop-shadow(0 0 20px #b57dff90)
        drop-shadow(0 0 40px #b57dff40);
    }
  }

  @keyframes flicker-purple {
    0%,
    100% {
      opacity: 1;
      filter: drop-shadow(0 0 8px #8957ff) drop-shadow(0 0 20px #8957ff90)
        drop-shadow(0 0 40px #8957ff40);
    }
    18% {
      opacity: 0.7;
      filter: drop-shadow(0 0 4px #8957ff80) drop-shadow(0 0 12px #8957ff40);
    }
    20% {
      opacity: 1;
      filter: drop-shadow(0 0 12px #8957ff) drop-shadow(0 0 28px #8957ff90)
        drop-shadow(0 0 50px #8957ff30);
    }
    45% {
      opacity: 0.8;
      filter: drop-shadow(0 0 6px #8957ff) drop-shadow(0 0 16px #8957ff70);
    }
    75% {
      opacity: 0.7;
      filter: drop-shadow(0 0 4px #8957ff80) drop-shadow(0 0 12px #8957ff40);
    }
    77% {
      opacity: 1;
      filter: drop-shadow(0 0 8px #8957ff) drop-shadow(0 0 20px #8957ff90)
        drop-shadow(0 0 40px #8957ff40);
    }
  }
</style>
