    <g class="neon-violet" filter="url(#neon-glow-violet)">
      <path
        d="M84.23,112.2c-2.25-1.61-2.47-5.02-.6-7.61,1.82-2.54,5.25-3.41,7.4-1.86,1.11.79,1.78,2.1,1.85,3.58.07,1.38-.38,2.81-1.25,4.02-1.93,2.69-5.23,3.42-7.4,1.86ZM85.98,106.28c-.92,1.29-.95,2.91-.06,3.55.85.62,2.46.04,3.34-1.19,1.1-1.54.77-3.05.06-3.55-.88-.64-2.42-.09-3.34,1.2Z"
      ></path>
    </g>
    <!-- White paths -->
    <g class="neon-white" filter="url(#neon-glow-white)">
      <path
        d="M55.58,149.12c4.01-.7,7.85-1.73,11.57-2.73,6.68-1.8,13.59-3.66,21.85-3.66,11.96,0,27.86-2.18,27.86-21.07,0-.8-.65-1.45-1.45-1.45s-1.45.65-1.45,1.45c0,12.73-7.46,18.17-24.95,18.17-8.65,0-15.74,1.91-22.61,3.76-3.82,1.03-7.42,2-11.31,2.68-11.82,2.05-16.01-8.69-17.01-12.03-1.47-4.92-1.55-11.74,6.35-16.28,6.76-3.89,15.98-12.46,18.96-15.43.57-.57.57-1.49,0-2.06-.57-.57-1.49-.57-2.06,0-2.9,2.9-11.86,11.24-18.35,14.97-7.46,4.28-10.19,11.26-7.69,19.63,2.8,9.39,10.02,15.85,20.29,14.07Z"
