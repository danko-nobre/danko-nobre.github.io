      ></path>
      <path
        d="M122.9,94.49c.51,0,1.01-.27,1.27-.75,14.2-25.56-1.09-47.42-6.23-47.47-.72.03-1.34.42-1.66,1.05-1.47,2.88-12.68,31.59-13.16,32.81-.29.75.08,1.59.83,1.88.74.3,1.59-.08,1.88-.83,3.7-9.49,10.71-27.26,12.66-31.71,4.27,3.13,15.39,20.81,3.15,42.85-.39.7-.14,1.59.57,1.98.22.12.47.18.7.18Z"
      ></path>
      <path
        d="M117.9,87.68c.51,0,1.01-.27,1.27-.75,4.08-7.34,1.52-14.56.19-16.72-.23-.38-.9-1.44-1.92-1.34-.52.02-1.08.38-1.32.85-.46.9-4.39,11.47-5.18,13.58-.28.75.10,1.59.86,1.87.75.29,1.59-.1,1.87-.86,1.2-3.23,2.94-7.87,4.04-10.74.86,2.66,1.47,7.36-1.07,11.94-.39.7-.14,1.59.57,1.98.22.12.46.18.7.18Z"
      ></path>
