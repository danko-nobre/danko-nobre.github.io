    </g>
    <!-- Pink (horn) -->
    <g class="neon-pink" filter="url(#neon-glow-pink)">
      <path
        d="M62.68,65.49c.33,0,.66-.07.98-.21,1.22-.54,1.78-1.97,1.24-3.19-7.26-16.43-14.42-34.83-15.93-42.03,5.36,5.04,17.41,20.75,27.33,34.99.76,1.09,2.27,1.37,3.37.6,1.1-.76,1.36-2.27.6-3.37C51.6,11.13,47.66,13.06,45.75,13.98c-2.13,1.03-6.1,2.96,14.72,50.07.39.91,1.28,1.44,2.21,1.44Z"
