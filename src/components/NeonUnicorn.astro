      ></path>
    </g>
    <!-- Purple path -->
    <g class="neon-purple-g" filter="url(#neon-glow-purple)">
      <path
        d="M46.88,134.2c.62,0,1.24-.24,1.72-.71.94-.95.94-2.48,0-3.42-.25-.25-.57-.56-.15-1.12.79-1.04.64-2.56-.38-3.38-1.02-.82-2.48-.72-3.34.28-1.34,1.56-2.33,4.89.44,7.65.47.47,1.1.71,1.72.71Z"
