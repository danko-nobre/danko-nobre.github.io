---
import Layout from "@layouts/Layout.astro";
import Hero from "@components/widgets/Hero.astro";
import About from "@components/widgets/About.astro";
import Projects from "@components/widgets/Projects.astro";
import TechStack from "@components/widgets/TechStack.astro";
import Contact from "@components/widgets/Contact.astro";
import Footer from "@components/widgets/Footer.astro";
import NeonUnicorn from "@components/NeonUnicorn.astro";
---

<Layout>
  <main class="min-h-screen bg-background relative">
    <!-- Neon Unicorn Background -->
    <div
      class="flex justify-center pt-8 md:pt-0 md:fixed md:bottom-16 md:right-16 pointer-events-none z-0 overflow-visible"
      aria-hidden="true"
    >
      <NeonUnicorn class="w-40 h-40 md:w-72 md:h-72 lg:w-96 lg:h-96" />
    </div>

    <!-- Content -->
    <div class="relative space-y-12 md:space-y-24 z-10">
      <Hero />
      <About />
      <Projects />
      <TechStack />
      <Contact />
      <Footer />
    </div>
  </main>
</Layout>
